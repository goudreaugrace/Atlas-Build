{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BrandHealthRecord",
  "type": "object",
  "required": ["brandId", "brandName", "country", "category", "period", "categoryLens", "metrics", "diagnosisIds"],
  "properties": {
    "brandId": {"type": "string"},
    "brandName": {"type": "string"},
    "country": {"type": "string"},
    "category": {"type": "string"},
    "period": {"type": "string"},
    "portfolioRole": {"type": "string"},
    "typology": {"type": ["string", "null"]},
    "pricingPower9Box": {"type": ["string", "null"]},
    "powerShare": {"type": ["number", "null"]},
    "categoryLens": {"type": "object"},
    "metrics": {"type": "object"},
    "trends": {"type": "object"},
    "occasions": {"type": "array"},
    "growthNavigator": {"type": ["object", "null"]},
    "diagnosisIds": {"type": "array", "items": {"type": "string"}},
    "sourceFiles": {"type": "array", "items": {"type": "string"}}
  }
}
